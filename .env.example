# Environment Configuration

# App
PORT=8091
APP_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/noti_db

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=ms-ga-noti

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
MAX_RETRIES=3

# Email Provider (sendgrid | ses)
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=
FROM_EMAIL=noreply@gymapi.com
FROM_NAME=GymAPI

# Push Notifications
FCM_SERVER_KEY=

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
